# Copy this file to .env and fill in your values

# Google OAuth credentials paths (generated by setup)
GOOGLE_CREDENTIALS_PATH=./credentials.json
GOOGLE_TOKEN_PATH=./token.json

# Google Drive folder IDs
GOOGLE_DRIVE_FOLDER_ID=          # root folder to watch for meeting folders
GOOGLE_DRIVE_OUTPUT_FOLDER_ID=   # where generated docs are saved
GOOGLE_EXTRA_CONTEXT_FOLDER_ID=  # optional: extra context docs folder

# Gmail
GMAIL_ACCOUNTS=you@gmail.com

# LLM
LLM_PROVIDER=openai               # openai | gemini
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
#GEMINI_API_KEY=
#GEMINI_MODEL=gemini-1.5-pro

# Email reports
SEND_SUMMARY_TO=you@example.com
EMAIL_FROM=you@gmail.com

# Database (matches docker-compose defaults)
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=meeting_agent
POSTGRES_USER=agent
POSTGRES_PASSWORD=changeme

# Agent
AGENT_OWNER_NAME=              # your name — only tasks assigned to you are auto-executed
AGENT_CRON_SCHEDULE=*/30 * * * *
MAX_ITERATIONS=10

# App
API_PORT=8001
FRONTEND_PORT=3000
SECRET_KEY=change-me-in-production
